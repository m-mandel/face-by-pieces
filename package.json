{
  "name": "face-by-pieces",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "24.13.0",
    "npm": "11.6.2"
  },
  "scripts": {
    "dev": "concurrently -k -n client,server -c cyan,magenta \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch --env-file-if-exists=.env server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node --env-file-if-exists=.env server/index.js",
    "report": "node --env-file-if-exists=.env server/report.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "vite": "^8.1.4"
  }
}
